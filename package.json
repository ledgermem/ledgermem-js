{
  "name": "@mnemo/memory",
  "version": "0.1.0",
  "description": "Official TypeScript / JavaScript SDK for Mnemo Memory — long-term memory infrastructure for AI agents.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "memory",
    "llm",
    "agents",
    "rag",
    "vector",
    "longmemeval",
    "mcp"
  ],
  "homepage": "https://getmnemo.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/getmnemo/getmnemo-js"
  },
  "bugs": {
    "url": "https://github.com/getmnemo/getmnemo-js/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
